<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alo Jetak</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: "Segoe UI", Tahoma, sans-serif;
    }

    body{
      height:100vh;
      background: linear-gradient(135deg,#0f172a,#1e293b,#334155);
      display:flex;
      justify-content:center;
      align-items:center;
      overflow:hidden;
      color:white;
    }

    .container{
      width:90%;
      max-width:420px;
      background:rgba(255,255,255,0.08);
      backdrop-filter: blur(18px);
      border:1px solid rgba(255,255,255,0.12);
      border-radius:28px;
      padding:40px 30px;
      text-align:center;
      box-shadow:0 10px 40px rgba(0,0,0,0.35);
      animation:fadeIn 1s ease;
    }

    .logo{
      width:110px;
      height:110px;
      border-radius:24px;
      margin:auto;
      margin-bottom:22px;
      object-fit:cover;
      box-shadow:0 8px 25px rgba(0,0,0,0.35);
    }

    h1{
      font-size:30px;
      margin-bottom:12px;
      font-weight:700;
    }

    p{
      opacity:.85;
      line-height:1.8;
      font-size:15px;
      margin-bottom:30px;
    }

    .loader{
      width:55px;
      height:55px;
      border:4px solid rgba(255,255,255,0.15);
      border-top:4px solid white;
      border-radius:50%;
      margin:auto;
      animation:spin 1s linear infinite;
    }

    .stores{
      display:flex;
      justify-content:center;
      gap:14px;
      margin-top:30px;
      flex-wrap:wrap;
    }

    .btn{
      padding:12px 20px;
      border-radius:14px;
      text-decoration:none;
      color:white;
      font-weight:600;
      transition:.3s;
      border:1px solid rgba(255,255,255,0.15);
      background:rgba(255,255,255,0.08);
    }

    .btn:hover{
      transform:translateY(-3px);
      background:rgba(255,255,255,0.15);
    }

    @keyframes spin{
      100%{
        transform:rotate(360deg);
      }
    }

    @keyframes fadeIn{
      from{
        opacity:0;
        transform:translateY(20px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <!-- ضع رابط لوجو التطبيق هنا -->
    <img
      class="logo"
      src="https://play-lh.googleusercontent.com/your-logo.png"
      alt="Alo Jetak"
    />

    <h1>ألو جيتك</h1>

    <p>
      جاري تحويلك إلى متجر التطبيق المناسب لجهازك...
    </p>

    <div class="loader"></div>

    <div class="stores">
      <a class="btn" href="https://play.google.com/store/apps/details?id=com.alojetak.app">
        Google Play
      </a>

      <a class="btn" href="https://apps.apple.com/il/app/%D8%A3%D9%84%D9%88-%D8%AC%D9%8A%D8%AA%D9%83/id6756861614">
        App Store
      </a>
    </div>

  </div>

  <script>

    const androidLink =
      "https://play.google.com/store/apps/details?id=com.alojetak.app";

    const iosLink =
      "https://apps.apple.com/il/app/%D8%A3%D9%84%D9%88-%D8%AC%D9%8A%D8%AA%D9%83/id6756861614";

    const userAgent =
      navigator.userAgent || navigator.vendor || window.opera;

    setTimeout(() => {

      if (/android/i.test(userAgent)) {

        window.location.href = androidLink;

      } else if (/iPad|iPhone|iPod/.test(userAgent)
        && !window.MSStream) {

        window.location.href = iosLink;

      } else {

        // لو جهاز كمبيوتر أو غير معروف
        window.location.href = androidLink;
      }

    }, 1800);

  </script>

</body>
</html>
